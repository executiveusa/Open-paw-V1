# Open Paw Environment Configuration
# Copy this file to .env and fill in values
# Never commit .env to version control

# ──────────────────────────────────────────
# API Service
# ──────────────────────────────────────────

# Bind address for the API server
API_HOST=127.0.0.1
API_PORT=3001

# Database (SQLite path for local mode)
DATABASE_URL=sqlite:./data/openpaw.db

# Secret for signing session tokens — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_generate_a_real_secret

# CORS allowed origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:4321

# Log level: trace | debug | info | warn | error
RUST_LOG=open_paw_api=info,tower_http=debug

# ──────────────────────────────────────────
# LLM Providers (all optional)
# ──────────────────────────────────────────

# OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic-compatible endpoint
ANTHROPIC_API_KEY=

# Ollama (local inference — no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ──────────────────────────────────────────
# Frontend Apps
# ──────────────────────────────────────────

# Public URL of the API (used by dashboard)
PUBLIC_API_URL=http://localhost:3001

# Landing site base URL
PUBLIC_SITE_URL=http://localhost:4321

# Dashboard base URL
PUBLIC_DASHBOARD_URL=http://localhost:5173
