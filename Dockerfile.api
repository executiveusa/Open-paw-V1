# Stage 1: Build
FROM rust:1.82-slim AS builder

WORKDIR /build

# Install build dependencies
RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*

# Cache workspace dependencies
COPY Cargo.toml Cargo.lock ./
COPY crates/core/Cargo.toml crates/core/
COPY crates/storage/Cargo.toml crates/storage/
COPY crates/auth/Cargo.toml crates/auth/
COPY crates/policy/Cargo.toml crates/policy/
COPY crates/llm/Cargo.toml crates/llm/
COPY crates/plugins/Cargo.toml crates/plugins/
COPY services/api/Cargo.toml services/api/

# Create dummy source files to cache deps
RUN mkdir -p crates/core/src && echo "pub fn main() {}" > crates/core/src/lib.rs
RUN mkdir -p crates/storage/src && echo "pub fn main() {}" > crates/storage/src/lib.rs
RUN mkdir -p crates/auth/src && echo "pub fn main() {}" > crates/auth/src/lib.rs
RUN mkdir -p crates/policy/src && echo "pub fn main() {}" > crates/policy/src/lib.rs
RUN mkdir -p crates/llm/src && echo "pub fn main() {}" > crates/llm/src/lib.rs
RUN mkdir -p crates/plugins/src && echo "pub fn main() {}" > crates/plugins/src/lib.rs
RUN mkdir -p services/api/src && echo "fn main() {}" > services/api/src/main.rs

RUN cargo build --release -p open-paw-api 2>&1 | tail -5

# Copy real source
COPY crates crates
COPY services services

# Touch to force rebuild
RUN touch crates/core/src/lib.rs crates/storage/src/lib.rs services/api/src/main.rs

ENV SQLX_OFFLINE=true
RUN cargo build --release -p open-paw-api

# Stage 2: Runtime
FROM debian:bookworm-slim AS runtime

RUN apt-get update && apt-get install -y ca-certificates libssl3 && rm -rf /var/lib/apt/lists/*

RUN useradd --system --create-home --shell /bin/bash openpaw

WORKDIR /app
RUN chown openpaw:openpaw /app

COPY --from=builder /build/target/release/open-paw-api /app/open-paw-api
COPY --chown=openpaw:openpaw crates/storage/migrations /app/migrations

RUN mkdir -p /app/data && chown openpaw:openpaw /app/data

USER openpaw

ENV API_HOST=0.0.0.0
ENV API_PORT=3001
ENV DATABASE_URL=sqlite:/app/data/openpaw.db
ENV RUST_LOG=open_paw_api=info,tower_http=info

EXPOSE 3001

VOLUME ["/app/data"]

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s \
  CMD curl -f http://localhost:3001/health || exit 1

CMD ["/app/open-paw-api"]
