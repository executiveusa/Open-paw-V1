5:[["$","$L10",null,{}],["$","main",null,{"children":["$","div",null,{"className":"py-16 px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"max-w-2xl mx-auto","children":[["$","$L11",null,{"href":"/blog","className":"inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-10","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":true,"children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Field Notes"]}],["$","header",null,{"className":"mb-10","children":[["$","div",null,{"className":"text-xs font-medium text-brand-600 dark:text-brand-400 mb-3","children":"Operations"}],["$","h1",null,{"className":"text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4 balance","children":"How to Track Foster Capacity Without a Spreadsheet Explosion"}],["$","time",null,{"className":"text-sm text-gray-400 dark:text-gray-500","children":"Jan 29, 2025"}]]}],["$","div",null,{"className":"prose-like","children":[["$","p","0",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Every rescue coordinator has a spreadsheet. Usually it's called something like \"Foster Master v7 FINAL (2).xlsx\" and it has seventeen tabs, color-coding that made sense six months ago, and formulas that break when someone types in the wrong column."}}],["$","p","1",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The spreadsheet works until it doesn't. Then you double-place an animal because two people updated different versions. Or a foster says they have capacity and you discover they already have three animals because the sheet wasn't synced."}}],["$","h3","2",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"The core problem"}],["$","p","3",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Foster capacity tracking fails because the data lives in a document, not a system. Documents don't enforce constraints. They don't notify you when things change. They don't prevent two people from entering conflicting information at the same time."}}],["$","h3","4",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"What a real system looks like"}],["$","p","5",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"In Open Paw, foster capacity is tracked as a property of each person record, not a row in a spreadsheet."}}],["$","p","6",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Each foster profile has:\n- Current placements (linked to actual animal records)\n- Maximum capacity (self-reported, updatable)\n- Species and size preferences\n- Status (active, on hold, full)\n- Contact information"}}],["$","p","7",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"When you try to place an animal with a foster who is full, the system tells you. When a placement ends, capacity updates automatically."}}],["$","h3","8",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"The placement board"}],["$","p","9",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The foster placement view shows you all your active fosters, their current animals, and their remaining capacity in one place. You can filter by species, location, or availability. When you have an animal that needs a foster, you can see in 30 seconds who can take it."}}],"$L12","$L13","$L14","$L15","$L16"]}],"$L17"]}]}]}],"$L18"]
12:["$","h3","10",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"Notifications without chaos"}]
13:["$","p","11",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Foster coordinators get notified when placements are approaching their planned end date. Fosters get a reminder when their commitment period is ending. This replaces the \"did anyone check on Biscuit's foster?\" conversation that happens in every rescue team."}}]
14:["$","h3","12",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"Making the transition"}]
15:["$","p","13",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"If you have a spreadsheet that works-ish, the migration path is: enter your active fosters as person records, link their current animals to them, and retire the spreadsheet. It takes an afternoon, and you only do it once."}}]
16:["$","p","14",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The goal isn't software for its own sake. The goal is knowing, at any moment, exactly which animals need fosters and exactly who can take them."}}]
