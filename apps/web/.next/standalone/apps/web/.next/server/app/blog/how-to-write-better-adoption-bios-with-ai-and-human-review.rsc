5:[["$","$L10",null,{}],["$","main",null,{"children":["$","div",null,{"className":"py-16 px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"max-w-2xl mx-auto","children":[["$","$L11",null,{"href":"/blog","className":"inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-10","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":true,"children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Field Notes"]}],["$","header",null,{"className":"mb-10","children":[["$","div",null,{"className":"text-xs font-medium text-brand-600 dark:text-brand-400 mb-3","children":"Adoptions"}],["$","h1",null,{"className":"text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4 balance","children":"How to Write Better Adoption Bios With AI and Human Review"}],["$","time",null,{"className":"text-sm text-gray-400 dark:text-gray-500","children":"Feb 12, 2025"}]]}],["$","div",null,{"className":"prose-like","children":[["$","p","0",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The hardest part of an adoption bio isn't describing the animal — it's finding the energy to write yet another one after a long intake shift."}}],["$","p","1",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The result: bios that are technically accurate but flat. \"Friendly dog, good with cats, loves walks.\" Every dog loves walks. Every dog is friendly. The bio doesn't help the adopter imagine this specific animal in their home."}}],["$","h3","2",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"What makes a good bio"}],["$","p","3",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"A good adoption bio does three things:"}}],["$","p","4",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"1. It describes the animal's personality in specific, memorable terms — not generic ones.\n2. It sets accurate expectations about the animal's needs.\n3. It creates an emotional connection without being manipulative."}}],["$","p","5",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"\"Luna is a gray tabby who believes all sunny spots belong to her and will judge you quietly if you disagree. She does well in calm households and would prefer a home without small children. She gives slow blinks freely.\" That's a bio that gets adopted."}}],["$","h3","6",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"Where AI helps"}],["$","p","7",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"AI-assisted bio drafting starts with the animal's intake notes, foster observations, and behavioral assessment. It generates a first draft that hits the structure and tone."}}],["$","p","8",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The draft is a starting point. It's usually 70-80% of the way there — better than starting from scratch, not good enough to post without review."}}],["$","h3","9",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"The review step"}],["$","p","10",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"In Open Paw, the AI draft goes into a review queue before it's visible on the public adoption page. A human reviewer — usually the foster coordinator or an experienced volunteer — reads it, edits for accuracy and voice, and approves it."}}],"$L12","$L13","$L14","$L15","$L16","$L17","$L18"]}],"$L19"]}]}]}],"$L1a"]
12:["$","p","11",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"This step is not optional. The AI doesn't know that Luna gets anxious in thunderstorms or that she hides for three days when she arrives in a new home. The foster knows. The bio should reflect that."}}]
13:["$","h3","12",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"What AI should never do"}]
14:["$","p","13",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Generate medical claims. Diagnose behavioral issues. Create a bio from nothing when there's no foster observation data. These are the guardrails that keep the system honest."}}]
15:["$","p","14",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The goal is better bios, faster. Not automated bios that could be wrong."}}]
16:["$","h3","15",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"The outcome"}]
17:["$","p","16",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Organizations that use structured bio workflows — whether with AI assistance or just a template — typically see faster adoption matches. The bio does more work. The animal spends less time in care."}}]
18:["$","p","17",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"That's the outcome that matters."}}]
