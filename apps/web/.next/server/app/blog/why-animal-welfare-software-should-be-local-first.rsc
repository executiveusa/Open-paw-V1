5:[["$","$L10",null,{}],["$","main",null,{"children":["$","div",null,{"className":"py-16 px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"max-w-2xl mx-auto","children":[["$","$L11",null,{"href":"/blog","className":"inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-10","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":true,"children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Field Notes"]}],["$","header",null,{"className":"mb-10","children":[["$","div",null,{"className":"text-xs font-medium text-brand-600 dark:text-brand-400 mb-3","children":"Technology"}],["$","h1",null,{"className":"text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4 balance","children":"Why Animal Welfare Software Should Be Local-First"}],["$","time",null,{"className":"text-sm text-gray-400 dark:text-gray-500","children":"Jan 15, 2025"}]]}],["$","div",null,{"className":"prose-like","children":[["$","p","0",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Most animal welfare software is designed like enterprise SaaS. You pay a monthly fee, your data lives on someone else's server, and if you lose internet access — or the vendor raises prices — you're stuck."}}],["$","p","1",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"That model works fine for organizations with IT departments and reliable broadband. It doesn't work for the rescue running out of a garage in a rural county, or the shelter whose wifi goes down every time it rains."}}],["$","h3","2",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"The case for local-first"}],["$","p","3",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Local-first software stores your data on your device. The application works offline. When you do have internet, you can sync or back up — but the sync is optional, not required."}}],["$","p","4",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"For animal welfare teams, this matters for three reasons:"}}],["$","h3","5",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"1. Sensitive records belong on your machine"}],["$","p","6",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Animal intake records, medical histories, and donor information are sensitive. Putting them in a third-party cloud means trusting that vendor's security, privacy policy, and business continuity. Local storage eliminates that dependency."}}],["$","h3","7",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"2. Connectivity is not universal"}],["$","p","8",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Foster families, transport volunteers, and field teams often work in places where connectivity is poor. Software that requires a live connection fails them exactly when they need it most."}}],["$","h3","9",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"3. Budget reality"}],["$","p","10",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Cloud subscriptions compound. A rescue with a $500/month software bill has to raise that money every month just to stand still. Local-first software, especially open-source, removes that recurring cost."}}],"$L12","$L13","$L14","$L15","$L16","$L17"]}],"$L18"]}]}]}],"$L19"]
12:["$","h3","11",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"What local-first doesn't mean"}]
13:["$","p","12",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Local-first doesn't mean no internet, ever. Open Paw supports optional cloud sync for teams that want it. It means your data isn't *hostage* to the cloud."}}]
14:["$","p","13",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"It also doesn't mean worse features. Local SQLite databases can be fast, reliable, and full-featured. The constraint is good design discipline."}}]
15:["$","h3","14",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"The tradeoff"}]
16:["$","p","15",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Local-first software is harder to build correctly. You have to think about sync conflicts, backup strategies, and offline state. That's why most vendors don't do it."}}]
17:["$","p","16",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Open Paw does it anyway, because the alternative — telling a rescue team they lost their animal records because the vendor went out of business — is not acceptable."}}]
