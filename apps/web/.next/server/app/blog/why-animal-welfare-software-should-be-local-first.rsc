9:{"metadata":[["$","title","0",{"children":"Why Animal Welfare Software Should Be Local-First | Open Paw"}],["$","meta","1",{"name":"description","content":"Shelter and rescue teams work in places with spotty internet, manage sensitive records, and operate on zero budget for cloud subscriptions. Local-first software is the only architecture that respects those constraints."}],["$","meta","2",{"property":"og:title","content":"Why Animal Welfare Software Should Be Local-First | Open Paw"}],["$","meta","3",{"property":"og:description","content":"Shelter and rescue teams work in places with spotty internet, manage sensitive records, and operate on zero budget for cloud subscriptions. Local-first software is the only architecture that respects those constraints."}],["$","meta","4",{"property":"og:site_name","content":"Open Paw"}],["$","meta","5",{"property":"og:type","content":"website"}],["$","meta","6",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","7",{"name":"twitter:title","content":"Why Animal Welfare Software Should Be Local-First | Open Paw"}],["$","meta","8",{"name":"twitter:description","content":"Shelter and rescue teams work in places with spotty internet, manage sensitive records, and operate on zero budget for cloud subscriptions. Local-first software is the only architecture that respects those constraints."}]],"error":null,"digest":"$undefined"}
