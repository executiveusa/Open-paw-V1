5:[["$","$L10",null,{}],["$","main",null,{"children":["$","div",null,{"className":"py-16 px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"max-w-2xl mx-auto","children":[["$","$L11",null,{"href":"/blog","className":"inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-10","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":true,"children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Field Notes"]}],["$","header",null,{"className":"mb-10","children":[["$","div",null,{"className":"text-xs font-medium text-brand-600 dark:text-brand-400 mb-3","children":"Operations"}],["$","h1",null,{"className":"text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4 balance","children":"How Fiscal Sponsors Can Support Animal Welfare Programs With Shared Tools"}],["$","time",null,{"className":"text-sm text-gray-400 dark:text-gray-500","children":"Mar 12, 2025"}]]}],["$","div",null,{"className":"prose-like","children":[["$","p","0",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Fiscal sponsorship is a model where an established nonprofit acts as the legal and financial umbrella for a program that doesn't have its own 501(c)(3) status. For animal welfare, this is increasingly common — a new rescue group operates under a larger organization's tax exemption while building toward independent status."}}],["$","p","1",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The challenge is infrastructure. The sponsored program needs software. The sponsor often has their own systems. The two don't talk."}}],["$","h3","2",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"The multi-tenant problem"}],["$","p","3",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"A fiscal sponsor supporting four sponsored animal welfare programs might have each program using a different spreadsheet, a different email address, a different filing system. Oversight becomes a coordination nightmare. Reporting requires manually aggregating data from four separate sources."}}],["$","h3","4",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"What shared infrastructure looks like"}],["$","p","5",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Open Paw is designed for multi-tenant operation. A fiscal sponsor can run a single Open Paw installation where each sponsored program has its own tenant — its own animal records, its own users, its own data."}}],["$","p","6",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The sponsor has a top-level view that shows aggregate activity across programs. They can run consolidated reports. They can see which programs are active, which have pending grant deadlines, and which animals are in care across their portfolio."}}],["$","p","7",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Each sponsored program sees only their own data. A volunteer at Program A cannot see Program B's animal records or donor information."}}],["$","h3","8",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"What this requires from the sponsor"}],"$L12","$L13","$L14","$L15","$L16","$L17","$L18"]}],"$L19"]}]}]}],"$L1a"]
12:["$","p","9",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Running shared infrastructure is a commitment. The sponsor needs someone who can administer the system, manage user accounts, and handle backups. For a large sponsor supporting many programs, this might be a part-time role. For a smaller sponsor, it might be a shared responsibility."}}]
13:["$","p","10",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The tradeoff: the infrastructure cost is borne once, not four times. Programs get production-quality software on day one instead of starting from spreadsheets."}}]
14:["$","h3","11",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"The grant reporting benefit"}]
15:["$","p","12",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"When sponsored programs use shared infrastructure, the sponsor can generate consolidated impact reports across all programs. Instead of asking four programs to submit quarterly data in four different formats, the sponsor generates the report directly from the system."}}]
16:["$","p","13",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"For funders who require consolidated reporting from fiscal sponsors, this removes a significant administrative burden."}}]
17:["$","h3","14",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"Starting point"}]
18:["$","p","15",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"For fiscal sponsors exploring this model, the practical starting point is: identify your highest-need sponsored programs, pilot the shared infrastructure with one or two, and expand from there. The goal is not to mandate tooling — it's to offer it as a service that reduces friction for everyone."}}]
