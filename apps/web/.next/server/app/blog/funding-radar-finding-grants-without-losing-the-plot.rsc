5:[["$","$L10",null,{}],["$","main",null,{"children":["$","div",null,{"className":"py-16 px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"max-w-2xl mx-auto","children":[["$","$L11",null,{"href":"/blog","className":"inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-10","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":true,"children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Field Notes"]}],["$","header",null,{"className":"mb-10","children":[["$","div",null,{"className":"text-xs font-medium text-brand-600 dark:text-brand-400 mb-3","children":"Funding"}],["$","h1",null,{"className":"text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4 balance","children":"The Open Paw Funding Radar: Finding Grants Without Losing the Plot"}],["$","time",null,{"className":"text-sm text-gray-400 dark:text-gray-500","children":"Jan 22, 2025"}]]}],["$","div",null,{"className":"prose-like","children":[["$","p","0",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Most animal welfare organizations are leaving grant money unclaimed — not because they don't qualify, but because grant research takes time nobody has."}}],["$","p","1",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The typical process looks like this: someone finds a relevant foundation, bookmarks it, means to come back to it, gets pulled into an intake emergency, and forgets. The deadline passes. Repeat."}}],["$","h3","2",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"What Funding Radar does"}],["$","p","3",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Funding Radar is a module inside Open Paw that turns grant management from a pile of browser bookmarks into a structured workflow."}}],["$","p","4",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"It has four main parts:"}}],["$","p","5",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"<strong>Funder database.</strong> A searchable, filterable list of grant sources with focus areas, geographic restrictions, award ranges, and contact information. You add funders you've found or import from the included resource directory."}}],["$","p","6",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"<strong>Grant calendar.</strong> Deadline tracking with alerts. When a grant you're tracking is 30 days out, you get a reminder. When it's 7 days out, you get another one. Missing deadlines because they snuck up on you stops being a thing."}}],["$","p","7",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"<strong>Eligibility checker.</strong> Before you spend three hours on an application, the eligibility tool checks your organization profile against the funder's criteria. 501(c)(3) status, service area, program type, annual budget range — the basics that disqualify most applicants before they start."}}],["$","p","8",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"<strong>AI-assisted narrative drafts.</strong> When you're ready to write, Funding Radar can generate a first-draft narrative based on your org profile, the grant's focus, and your recent program data. The draft requires human review before anything is submitted. This is not an auto-submit system. It's a starting point that saves the blank-page problem."}}],"$L12","$L13","$L14","$L15","$L16","$L17"]}],"$L18"]}]}]}],"$L19"]
12:["$","h3","9",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"What it doesn't do"}]
13:["$","p","10",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Funding Radar doesn't submit applications for you. It doesn't promise you'll win grants. It doesn't scrape funder websites without permission."}}]
14:["$","p","11",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"The AI draft is a starting point, not a final product. Every narrative should be reviewed, edited, and approved by a human who knows your organization. The tool accelerates the process; it doesn't replace judgment."}}]
15:["$","h3","12",{"className":"text-lg font-semibold text-gray-900 dark:text-white mt-8 mb-3","children":"Who it's for"}]
16:["$","p","13",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"Any rescue or shelter that has tried to track grants in a spreadsheet, lost a deadline, or given up because the research felt like a second full-time job."}}]
17:["$","p","14",{"className":"text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4","dangerouslySetInnerHTML":{"__html":"If that's you, Funding Radar is built for you."}}]
