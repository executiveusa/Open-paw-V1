---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Download Open Paw — Free Animal Welfare Software">
  <section class="pt-20 pb-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-4">Download Open Paw</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 mb-12 max-w-2xl mx-auto">Free, open-source, no account required. Your data stays local.</p>
      <div class="bg-amber-50 dark:bg-amber-950/30 border border-amber-200 dark:border-amber-800 rounded-2xl p-8 mb-12">
        <div class="text-2xl mb-3" aria-hidden="true">🚧</div>
        <h2 class="text-lg font-semibold text-amber-900 dark:text-amber-300 mb-2">Pre-alpha</h2>
        <p class="text-amber-800 dark:text-amber-400 text-sm leading-relaxed">
          Open Paw is in early development. The desktop installer is not yet ready. Star the repo on GitHub to be notified when V1 ships.
        </p>
        <a href="https://github.com/executiveusa/Open-paw-V1" class="mt-4 inline-flex items-center px-5 py-2.5 rounded-lg bg-amber-900 dark:bg-amber-300 text-white dark:text-amber-900 text-sm font-semibold hover:opacity-90 transition-opacity">
          Star on GitHub
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {[
          { os: 'macOS', icon: '🍎', note: 'Universal binary — Apple Silicon & Intel' },
          { os: 'Windows', icon: '🪟', note: 'Windows 10 and later' },
          { os: 'Linux', icon: '🐧', note: 'AppImage and .deb packages' },
        ].map(item => (
          <div class="p-6 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 text-left">
            <div class="text-3xl mb-3" aria-hidden="true">{item.icon}</div>
            <div class="text-sm font-semibold text-gray-900 dark:text-white mb-1">{item.os}</div>
            <div class="text-xs text-gray-500 dark:text-gray-400 mb-4">{item.note}</div>
            <button disabled class="w-full px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-400 dark:text-gray-600 text-xs font-medium cursor-not-allowed">Coming Soon</button>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
