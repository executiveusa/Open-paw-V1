---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Documentation — Open Paw">
  <section class="pt-20 pb-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">Documentation</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 mb-12">Everything you need to install, run, and contribute to Open Paw.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          { title: 'Local Development', desc: 'Set up the full dev environment', href: 'https://github.com/executiveusa/Open-paw-V1/blob/main/docs/LOCAL_DEVELOPMENT.md' },
          { title: 'Architecture', desc: 'System design and crate structure', href: 'https://github.com/executiveusa/Open-paw-V1/blob/main/docs/ARCHITECTURE.md' },
          { title: 'API Reference', desc: 'REST API endpoints and schemas', href: 'https://github.com/executiveusa/Open-paw-V1/blob/main/docs/API.md' },
          { title: 'Funding Radar', desc: 'Grant workflow and data model', href: 'https://github.com/executiveusa/Open-paw-V1/blob/main/docs/FUNDING_RADAR.md' },
          { title: 'Security Model', desc: 'Roles, permissions, and policies', href: 'https://github.com/executiveusa/Open-paw-V1/blob/main/docs/SECURITY.md' },
          { title: 'Contributing', desc: 'How to contribute to Open Paw', href: 'https://github.com/executiveusa/Open-paw-V1/blob/main/CONTRIBUTING.md' },
        ].map(doc => (
          <a href={doc.href} class="group p-5 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 hover:shadow-md transition-all">
            <h2 class="text-sm font-semibold text-gray-900 dark:text-white mb-1 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{doc.title}</h2>
            <p class="text-xs text-gray-500 dark:text-gray-400">{doc.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
